<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/panel_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#66000000"
    android:clickable="true"
    android:focusable="true">

    <!-- Transparent clickable area to close -->
    <View
        android:id="@+id/panel_dismiss_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true" />

    <!-- Bottom Sheet Card -->
    <LinearLayout
        android:id="@+id/panel_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_glass_card_dark"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp"
        android:paddingTop="12dp">

        <!-- Drag Handle -->
        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:background="#33FFFFFF"
            android:backgroundTint="#33FFFFFF" />

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/btn_panel_close"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/panel_job_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="React Developer"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/panel_job_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Acme Corp • Remote"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_panel_close"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"
                android:src="@drawable/ic_x"
                app:tint="@color/text_muted" />
        </RelativeLayout>

        <!-- Fit Score Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp">

                <ProgressBar
                    android:id="@+id/panel_score_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="82"
                    android:progressDrawable="@drawable/circular_progress" />

                <TextView
                    android:id="@+id/panel_score_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="82%"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:id="@+id/panel_fit_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Strong Match"
                android:textColor="@color/color_success"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/panel_fit_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Excellent job fit"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Analysis Points -->
        <LinearLayout
            android:id="@+id/panel_analysis_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp" />

        <!-- Actions -->
        <Button
            android:id="@+id/btn_auto_fill"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_gradient_primary_button"
            android:backgroundTint="@null"
            android:text="⚡ Auto Fill Form"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_view_analysis"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="View Full Analysis"
            android:textColor="@color/primary_purple"
            app:strokeColor="@color/primary_purple"
            app:strokeWidth="1.5dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_skip"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Skip"
            android:textColor="@color/text_muted" />

    </LinearLayout>
</FrameLayout>
