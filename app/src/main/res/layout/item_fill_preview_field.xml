<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <ImageView
        android:id="@+id/img_field_icon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_user"
        app:tint="@color/text_muted" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_field_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Field Label"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_field_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Value"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <View
        android:id="@+id/view_field_status"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_badge_success" />
</LinearLayout>
